<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.RingtonePlayer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/bg_silk_deep</item>
        <item name="colorSecondary">@color/hot_pink</item>
        <item name="android:windowBackground">@color/bg_silk_deep</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">false</item>
    </style>

    <style name="Theme.RingtonePlayer" parent="Base.Theme.RingtonePlayer" />

    <!-- ثيم الحوار المخصص ليكون واضحاً وداكناً بنصوص بيضاء متوهجة -->
    <style name="CustomDialogTheme" parent="Theme.Material3.Dark.Dialog.Alert">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:background">@color/bg_deep_navy</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_white_secondary</item>
        <item name="android:textColorAlertDialogListItem">@color/white</item>
        <item name="colorSurface">@color/bg_deep_navy</item>
        <item name="colorPrimary">@color/accent_neon_pink</item>
        <item name="android:listChoiceIndicatorSingle">@color/accent_neon_pink</item>
    </style>

    <style name="TransparentBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/TransparentBottomSheetStyle</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>

    <style name="TransparentBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@color/bg_deep_navy</item>
        <item name="shapeAppearanceOverlay">@style/CustomShapeAppearanceBottomSheet</item>
    </style>

    <style name="CustomShapeAppearanceBottomSheet" parent="">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
    </style>
</resources>