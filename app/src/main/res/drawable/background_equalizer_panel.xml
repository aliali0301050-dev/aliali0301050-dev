<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark Shadow -->
    <item
        android:bottom="0dp"
        android:left="4dp"
        android:right="0dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#FF000000" />
        </shape>
    </item>

    <!-- Light Shadow -->
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="4dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- Surface -->
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <solid android:color="#121212" />
            <stroke
                android:width="1dp"
                android:color="#0DFFFFFF" />
        </shape>
    </item>
</layer-list>