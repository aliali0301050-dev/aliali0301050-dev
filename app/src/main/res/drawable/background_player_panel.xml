<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow Dark (Bottom Right) -->
    <item
        android:bottom="0dp"
        android:left="4dp"
        android:right="0dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#60000000" />
        </shape>
    </item>

    <!-- Shadow Light (Top Left) -->
    <item
        android:bottom="4dp"
        android:left="0dp"
        android:right="4dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Panel Face -->
    <item
        android:bottom="3dp"
        android:left="3dp"
        android:right="3dp"
        android:top="3dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="135"
                android:endColor="#E0E0E0"
                android:startColor="#F0F0F0"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
        </shape>
    </item>
</layer-list>