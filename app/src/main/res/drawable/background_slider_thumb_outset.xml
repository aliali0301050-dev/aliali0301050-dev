<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow Dark (Bottom Right) -->
    <item
        android:bottom="0dp"
        android:left="2dp"
        android:right="0dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#60000000" />
        </shape>
    </item>

    <!-- Shadow Light (Top Left) -->
    <item
        android:bottom="2dp"
        android:left="0dp"
        android:right="2dp"
        android:top="0dp">
        <shape android:shape="oval">
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>

    <!-- Thumb Face (Golden) -->
    <item
        android:bottom="1dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:endColor="#FFC107"
                android:startColor="#FFD54F"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>