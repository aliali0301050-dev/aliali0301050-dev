<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/skinCircular"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- هالة ضوئية ناعمة جداً خلف القرص -->
    <View
        android:id="@+id/auraView"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="@color/theme_accent_neon"
        android:alpha="0.1"
        app:layout_constraintBottom_toBottomOf="@id/seekBar"
        app:layout_constraintEnd_toEndOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="@id/seekBar"
        app:layout_constraintTop_toTopOf="@id/seekBar" />

    <!-- حلقة التقدم النيونية النحيفة (Elegant Ring) -->
    <com.example.ringtoneplayer.ui.CircularSeekBar
        android:id="@+id/seekBar"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- صورة الألبوم بتصميم زجاجي ملكي -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/albumCard"
        android:layout_width="210dp"
        android:layout_height="210dp"
        app:cardBackgroundColor="#000000"
        app:cardCornerRadius="105dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@id/seekBar"
        app:layout_constraintEnd_toEndOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="@id/seekBar"
        app:layout_constraintTop_toTopOf="@id/seekBar"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1.5dp">

        <ImageView
            android:id="@+id/ivMainAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_music_note" />
    </com.google.android.material.card.MaterialCardView>

    <!-- نقطة النيون المشعة (تتحرك مع الخط) -->
    <View
        android:id="@+id/neonDot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="@color/theme_accent_neon"
        android:elevation="10dp"
        app:layout_constraintCircle="@id/albumCard"
        app:layout_constraintCircleAngle="270"
        app:layout_constraintCircleRadius="140dp" />

    <!-- وقت التشغيل والوقت الإجمالي (بخط نحيف فخم) -->
    <TextView
        android:id="@+id/tvCurrentTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="00:00"
        android:textColor="@color/text_low_emphasis"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        app:layout_constraintStart_toStartOf="@id/seekBar"
        app:layout_constraintTop_toBottomOf="@id/seekBar" />

    <TextView
        android:id="@+id/tvTotalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="00:00"
        android:textColor="@color/text_low_emphasis"
        android:textSize="11sp"
        android:letterSpacing="0.05"
        app:layout_constraintEnd_toEndOf="@id/seekBar"
        app:layout_constraintTop_toBottomOf="@id/seekBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
